)
# View the plot
print(map_plot)
# Save the pie charts
# We keep the dimensions large so the grid of pie charts doesn't get squished
View(struct_df_simplified)
View(df_unified_enriched)
library(tidyverse)
# 1. Read the base data
# 1. Read the base data
struct_df <- read_tsv("sliding_window_dists_to_ref.500.all_struct_examples.tsv")
# 2. Create the simplified version with exceptions for B2 and B8
struct_df_simplified <- struct_df %>%
mutate(
# --- PREPARATION ---
# Temporarily protect B2 and B8.
# (The `(?![0-9])` ensures we only match exactly B2 or B8, and not B20 or B21)
protected_wsize = str_replace_all(hap_struct_wsize, "B2(?![0-9])", "B_TWO"),
protected_wsize = str_replace_all(protected_wsize, "B8(?![0-9])", "B_EIGHT"),
# --- RULE 1: Letters Only ---
# Removes all digits (0-9) and dashes (-).
# Because B2 is currently "B_TWO", its numbers are safe from deletion!
hap_struct_letters = gsub("[0-9-]", "", protected_wsize),
# --- RULE 2: Letters + Suffix ---
# Replaces a letter followed by numbers with just the letter.
# Again, "B_TWO" contains no numbers, so the regex skips over it.
hap_struct_suffix = gsub("([a-zA-Z])[0-9]+", "\\1", protected_wsize)
) %>%
# --- RESTORATION ---
# Swap the placeholders back to their original B2 and B8 values
mutate(
hap_struct_letters = str_replace_all(hap_struct_letters, "B_TWO", "B2"),
hap_struct_letters = str_replace_all(hap_struct_letters, "B_EIGHT", "B8"),
hap_struct_suffix = str_replace_all(hap_struct_suffix, "B_TWO", "B2"),
hap_struct_suffix = str_replace_all(hap_struct_suffix, "B_EIGHT", "B8")
) %>%
# Clean up by removing the temporary column
select(-protected_wsize)
# View the result to confirm it worked!
print(head(struct_df_simplified))
meta_df <- read_tsv("human579.meta.tsv",
col_names = c("sample", "sex_chrom", "id", "sex", "continent", "sub_region", "country", "data_source"))
# 2. Read the NEW metadata file
new_meta <- read_tsv("METADATA_4099_p1p2.tsv")
# 3. Create the unified dataframe
df_unified <- struct_df_simplified %>%
inner_join(meta_df, by = "sample") %>%
mutate(location = if_else(country != ".", country, sub_region))
# 4. Create a unique lookup table from the NEW metadata BY POPULATION ONLY
pop_lookup <- new_meta %>%
select(
hgdp_tgp_meta.Population,
Latitude = hgdp_tgp_meta.Latitude,
Longitude = hgdp_tgp_meta.Longitude,
Continent_color = hgdp_tgp_meta.Continent.colors,
Population_color = hgdp_tgp_meta.Pop.colors
) %>%
# Keep only one set of coordinates/colors per population
distinct(hgdp_tgp_meta.Population, .keep_all = TRUE)
# 5. Enrich df_unified by joining ONLY on the location/population match
df_unified_enriched <- df_unified %>%
left_join(pop_lookup, by = c("location" = "hgdp_tgp_meta.Population"))
# Check the results!
head(df_unified_enriched)
# 3. Calculate frequencies for the unified dataset
df_freq <- df_unified %>%
# Group by our new unified 'location' column
group_by(continent, location, hap_struct_suffix) %>%
summarise(count = n(), .groups = "drop") %>%
# Calculate frequency relative to the total in that specific location
group_by(continent, location) %>%
mutate(frequency = count / sum(count))
# 4. Create the unified plot
unified_plot <- ggplot(df_freq, aes(x = location, y = frequency, fill = hap_struct_suffix)) +
geom_col(position = "dodge") +
facet_grid(~ continent, scales = "free_x", space = "free_x") +
theme_classic() +
scale_y_continuous(labels = percent_format()) +
labs(
title = "Relative Frequency of hap_struct_suffix per Location (Country / Sub-region)",
x = "Location",
y = "Frequency",
fill = "hap_struct_suffix"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
strip.text = element_text(face = "bold", size = 10),
panel.border = element_rect(fill = NA, color = "grey80")
)
# Display the plot
print(unified_plot)
