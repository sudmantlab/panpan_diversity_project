def get_simple_cluster_pafs(wildcards):
    
    min_diff = 500
    fn_coords = "output/{species}/{loc}/sequences.fa.fai".format(species=wildcards.species,
                                                                 loc=wildcards.loc)
    if not os.path.exists(fn_coords):
        return []

    t = pd.read_csv(fn_coords, sep='\t', header=None, names=['contig', 'length', 'd1', 'd2', 'd3'])
    t = t.sort_values(by="length")

    #kill crazies
    t = t[t.length<15000000]

    diff = np.diff(t.length, prepend=0)
    t = t[diff>min_diff]

    inputs = []
    prev_sample = ""
    
    for i, row in t.iterrows():
        sample=row['contig'].split("@")[0]
        if prev_sample != "":
            fn = "output/{species}/{loc}/sequential_pafs/{s1}:{s2}.full.paf".format(species=wildcards.species,
                                                                                 s1=prev_sample,
                                                                                 s2=sample,
                                                                                 loc=wildcards.loc)
            inputs.append(fn)

        prev_sample = sample
    return inputs

rule sequential_combine_pafs:
    input:
        "output/{species}/{loc}/sequences.fa.fai",
        get_simple_cluster_pafs
    output:
        "output/{species}/{loc}/hap_alignments/simple_cluster_sequential.full.paf",
        "output/{species}/{loc}/hap_alignments/simple_cluster_sequential.no_secondary.paf"
    run:
        fns = input[1:]
        cmd = "cat {fn_in} >{fn_out}".format(fn_in=" ".join(fns), fn_out=output[0])
        shell(cmd) 
        fns_no_sec = [f.replace("full","no_secondary") for f in fns]
        cmd = "cat {fn_in} >{fn_out}".format(fn_in=" ".join(fns_no_sec), fn_out=output[1])
        shell(cmd) 
        #"minimap2 -x asm20 -c --eqx -D -P -t 24 --dual=no {input[0]} {input[0]} > {output[0]}"



