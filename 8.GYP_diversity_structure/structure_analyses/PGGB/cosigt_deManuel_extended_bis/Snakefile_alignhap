def get_bespoke_seq_pafs(wildcards):

    samples = bespoke_seq_aln[wildcards.species][wildcards.loc][wildcards.name]
    inputs = []
    prev_sample = ""
    for sample in samples:
        sample=sample.split("@")[0]
        if prev_sample  != "":
            fn = "output/{species}/{loc}/sequential_pafs/{s1}:{s2}.full.paf".format(species=wildcards.species,
                                                                                    loc=wildcards.loc,
                                                                                    s1=prev_sample,
                                                                                    s2=sample)
            inputs.append(fn)

        prev_sample = sample
    return inputs

rule bespoke_combine_pafs:
    input:
