def get_fasta_inputs(wildcards):
    inputs = []
    
    fn_coords = "output/{species}/{loc}/sample_coords.txt".format(species=wildcards.species,
                                                                  loc=wildcards.loc)
    if not os.path.exists(fn_coords):
        return []
    t = pd.read_csv(fn_coords, sep='\t', header=None, names=['contig', 'start', 'end', 'sample','strand'])
    for i, row in t.iterrows():
        sample=row['sample']
        inputs.append("output/{species}/{loc}/sample_fastas/{sample}.fa".format(species=wildcards.species,
                                                                                loc = wildcards.loc,
                                                                                sample=sample))
    return inputs

rule combine_fastas:
    input:
        "output/{species}/{loc}/sample_coords.txt",
        get_fasta_inputs
    output:
        "output/{species}/{loc}/sequences.fa"
    run:
        cmd = "cat {inputs} > {output}".format(inputs=" ".join(input[1:]), output=output[0])
        shell(cmd)

