def get_sample_coords_inputs(wildcards):
    inputs = []
    for s in samples_by_species[wildcards.species]:
        inputs.append("output/{species}/{loc}/sample_liftovers/{s}.paf".format(species=wildcards.species,
                                                                               loc = wildcards.loc,
                                                                               s=s))
    return inputs

checkpoint get_sample_coords:
    input:
        get_sample_coords_inputs
    output:
        "output/{species}/{loc}/sample_coords.txt"
    run:
        outrows = []
        s = 0
        e = 0
        for f in input:
            sample = f.replace(".paf","").split("/")[-1]
            t = pd.read_csv(f, sep="\t", header=None, names = ["qcontig","start","end","tcontig","match","strand"])
            if t.shape[0] == 0:
                continue
            s = t['start'].min()
            e = t['end'].max()
            contig=t['qcontig'][0]
            strand=t['strand'][0]
            #not needed as AGC is in NCBI 
            #if wildcards.species == "HSA":
            #    contig = HSA_NCBI_to_UCSC[contig]
            outrows.append({"contig":contig, "start":s, "end":e, "sample":sample, "strand":strand})

        t = pd.DataFrame(outrows)
        t.to_csv(output[0], sep="\t", index=False, header=False)

