def get_windowed_pafs(wildcards):
    inputs = []

    fn = CAT_ANNOTATIONS_BY_SPECIES[wildcards.species]
    t = pd.read_table(fn, header=0, sep="\t")
    for i, row in t.iterrows():
        sample = "{name}:{s}-{e}:{type}_{gene}".format(name=row['contig'], 
                                                           s=row['gene_start'], 
                                                           e=row['gene_end'],
                                                           type=row["category"],
                                                           gene=row['corrected_label'])
        fn = "output/{species}/{loc}/CAT_gene_annotation_analysis/{ref}/windowed_mappings.{w}/{sample}.paf"
        fn = fn.format(species = wildcards.species,
                       loc = wildcards.loc, 
                       sample = sample,
                       w=wildcards.w,
                       ref=wildcards.ref)
        inputs.append(fn)

    return inputs
    
rule merge_adjacent_windows:
    input:
        "output/{species}/{loc}/CAT_gene_annotation_analysis/{ref}/sliding_window_dists_to_ref.{w}.tsv"
    output:
        "output/{species}/{loc}/CAT_gene_annotation_analysis/{ref}/merged_sliding_window_dists_to_ref.{w}.tsv"
    run:
        t = pd.read_csv(input[0], header=0, sep="\t")
        t[["gene_query", "gene_relstart", "s_e"]] = t['query'].str.split('@', expand=True)
        t[["_sample", "rel_start_end", "info"]] = t['gene_query'].str.split(':', expand=True)
        t[["query_start", "query_end"]] = t['rel_start_end'].str.split('-', expand=True)
        t = t.drop(columns = ["_sample","info","rel_start_end","rel_start"])
        t = t.sort_values(["gene_query","s","e"])
        
        #t = t[t['gene_query']=="HG02554.1.chr:365137-394515:fusion_GYPA"]
        t['key_change'] = (t.target != t.target.shift()).cumsum()
        #t['adjacent'] = t.s - t.e.shift()

        clustered = t.groupby(['gene_query',
                   "query_start",
                   "query_end",
                   'sample',
                   'target', 
                   'key_change']).agg({'s': 'min','e': 'max'}).reset_index()

        #clustered = clustered[clustered['sample']=="HG02554.1.chr"].sort_values(["gene_query","s"])
        clustered = clustered.sort_values(["gene_query","s"])
        #pdb.set_trace()

        #t['run_id'] = (key_change | dist_gap).cumsum()
        #dist_gap = (df['start'] - df['end'].shift()) > 50 
        #df['run_id'] = (df['start'] != df['window'].shift()).cumsum()
        #group by query
        clustered.to_csv(output[0], sep="\t", index=False)


