rule get_sequence:
    input:
        #"output/{species}/{loc}/minimap_pafs_combined/minimap_unspliced.best_matches.bed",
        #"output/{species}/{loc}/unspliced_alignment_seqs/unspliced_alignment_best_seqs.fa"
        "output/{species}/{loc}/CAT_gene_annotations/full_transcript_regions.annotated.fa",
    output:
        #"output/{species}/{loc}/unspliced_alignment_seqs/windowed_seqs.{w}/{sample}.fa"
        "output/{species}/{loc}/CAT_gene_annotation_analysis/{ref}/windowed_seqs.{w}/{sample}.fa"
    run:
        fasta_sequences = SeqIO.parse(open(input[0]),'fasta') 
        out_seqs = []
        for fa in fasta_sequences:
            sample = fa.id

            curr_rel_coord_s = sample.split(":")[1].split("-")[0]
            curr_rel_coord_e = sample.split(":")[1].split("-")[1]
            #w = 2000
            w = int(wildcards.w)
            
            start = 0
            end = start + w
            if sample == wildcards.sample:
                while start<len(fa.seq):
                    curr_id = "{sample}@{rel_coord_s}-{rel_coord_e}@{s}-{e}"
                    curr_id = curr_id.format(sample=sample,
                                             rel_coord_s = curr_rel_coord_s,
                                             rel_coord_e = curr_rel_coord_e,
                                             s=start,
                                             e = end)
                    out_seqs.append(SeqRecord(Seq(fa.seq[start:end]), 
                                    id=curr_id,
                                    description=""))
                    start = end
                    if start+2*w > len(fa.seq):
                        end = len(fa.seq)
                    else:
                        #end = min(len(fa.seq), start+w)
                        end = start+w
        
        SeqIO.write(out_seqs, output[0], "fasta")


