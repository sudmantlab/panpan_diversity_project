new_scale_fill() +
# Layer 4: Pie Charts
geom_scatterpie(data = pop_pie_data,
aes(x = Plot_Long, y = Plot_Lat, r = radius),
cols = pie_cols, color = "white", linewidth = 0.1) +
# Layer 5: Categorical Legend for Haplotypes
scale_fill_manual(values = expanded_colors,
breaks = all_structs,
name = "Structural Haplogroup") +
# Styling & Camera View
coord_sf(xlim = c(-20, 50), ylim = c(-10, 20), expand = FALSE) +
theme_minimal() +
theme(
legend.position = "right",
legend.text = element_text(size = 6),
legend.title = element_text(face = "bold", size = 9),
panel.background = element_rect(fill = "white"),
panel.grid = element_blank(),
plot.title = element_text(face = "bold", size = 14),
plot.subtitle = element_text(size = 10, color = "grey30")
) +
labs(
title = "Chimpanzee GYP Diversity vs. Mean Temperature",
subtitle = "Background: WorldClim Historical Baseline (Bio1)",
x = "Longitude", y = "Latitude"
)
# 3. Print and Save
print(ordered_temp_map)
print(figure_turnover_temp)
figure_turnover_temp <- ggplot() +
stat_smooth(data = temp_freq_summary,
aes(x = temp_val, y = Frequency, color = Structure, fill = Structure),
method = "loess", span = 0.75, alpha = 0.1, linewidth = 1) +
# 24.5 °C Malaria Optimum Reference
geom_vline(aes(xintercept = 24.5), linetype = "dotted", color = "red", linewidth = 0.8) +
annotate("text", x = 24.5, y = 0.95, label = "24.5 °C Malaria Optimum",
angle = 90, vjust = -0.5, size = 4, color = "red", fontface = "bold") +
# Species Median Reference
geom_vline(aes(xintercept = global_temp_median), linetype = "dashed", color = "grey40") +
annotate("text", x = global_temp_median, y = 0.05,
label = paste0("median", round(global_temp_median, 1), " °C"),
angle = 90, vjust = 1.5, size = 3.5, color = "grey40", fontface = "italic") +
scale_color_manual(values = expanded_colors) +
scale_fill_manual(values = expanded_colors) +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
theme_minimal() +
theme(
legend.position = "right",
legend.text = element_text(size = 6, family = "mono"),
legend.title = element_text(face = "bold", size = 9),
panel.grid.minor = element_blank()
) +
guides(fill = guide_legend(ncol = 1), color = guide_legend(ncol = 1)) +
labs(
x = "Mean Annual Temperature (°C)",
y = "Relative Frequency (%)"
)
