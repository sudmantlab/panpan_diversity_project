stat_smooth(data = temp_freq_summary,
aes(x = temp_val, y = Frequency, color = Structure, fill = Structure),
method = "loess",
span = 0.75,
se = FALSE,      # <--- THIS REMOVES THE SHADOWS
linewidth = 1.5) + # Made slightly thicker to look like 'thick lines'
# 24.5 °C Malaria Optimum Reference
geom_vline(aes(xintercept = 24.5), linetype = "dotted", color = "red", linewidth = 0.8) +
annotate("text", x = 24.5, y = 0.95, label = "24.5°C Malaria Optimum",
angle = 90, vjust = -0.5, size = 2, color = "red", fontface = "bold") +
# Species Median Reference
geom_vline(aes(xintercept = global_temp_median), linetype = "dashed", color = "grey40") +
annotate("text", x = global_temp_median, y = 0.05,
label = paste0("Median: ", round(global_temp_median, 1), " °C"),
angle = 90, vjust = 1.5, size = 2, color = "grey40", fontface = "italic") +
scale_color_manual(values = expanded_colors) +
scale_fill_manual(values = expanded_colors) +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
theme_classic() +
theme(
legend.position = "right",
legend.text = element_text(size = 6, family = "mono"),
legend.title = element_text(face = "bold", size = 9),
panel.grid.minor = element_blank()
) +
guides(fill = guide_legend(ncol = 1), color = guide_legend(ncol = 1)) +
labs(
x = "Mean Annual Temperature (°C)",
y = "Haplotype Frequency"
)
print(figure_turnover_temp)
ggsave("forest_filtered/Global_Turnover_Temperature_Clean.pdf", figure_turnover_temp, width = 5.5, height = 3)
figure2_global_forest <- ggplot() +
stat_smooth(data = global_struct_data, aes(x = tree_cover * 100, y = Frequency, color = Structure, fill = Structure),
method = "loess", span = 0.75, alpha = 0.1, se = FALSE, linewidth = 1) +
geom_vline(aes(xintercept = global_median * 100), linetype = "dashed", color = "grey40") +
annotate("text", x = (global_median * 100), y = 0.95, label = paste0("median", round(global_median * 100, 1), "%"),
angle = 90, vjust = -0.5, size = 2, color = "grey30", fontface = "italic") +
scale_color_manual(values = expanded_colors) + scale_fill_manual(values = expanded_colors) +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
theme_classic() +
theme(legend.position = "right", legend.text = element_text(size = 6, family = "mono")) +
guides(fill = guide_legend(ncol = 1), color = guide_legend(ncol = 1)) +
labs(x = "Tree Cover %", y = "Haplotype Frequency")
print(figure2_global_forest)
ggsave("forest_filtered/Global_Hansen_Final.pdf", figure2_global_forest, width = 5, height = 3)
figure2_global_precip <- ggplot() +
stat_smooth(data = global_precip_struct, aes(x = precip_val, y = Frequency, color = Structure, fill = Structure),
method = "loess", span = 0.75, se = FALSE, alpha = 0.1, linewidth = 1) +
geom_vline(aes(xintercept = global_precip_median), linetype = "dashed", color = "grey40") +
annotate("text", x = global_precip_median, y = 0.95, label = paste0("", round(global_precip_median, 0), " mm"),
angle = 90, vjust = -0.5, size = 2, color = "grey30", fontface = "italic") +
scale_color_manual(values = expanded_colors) + scale_fill_manual(values = expanded_colors) +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
theme_classic() +
theme(legend.position = "right", legend.text = element_text(size = 6, family = "mono")) +
guides(fill = guide_legend(ncol = 1), color = guide_legend(ncol = 1)) +
labs(x = "Annual Precipitation (mm)", y = "Haplotype Frequency")
print(figure2_global_precip)
ggsave("forest_filtered/Global_Rainfall_Final.pdf", figure2_global_precip, width = 5.5, height = 3)
